<script lang="ts" setup>
import Header from "./Header.vue";
import { inject, watch, ref, type Ref } from "vue";
import { usePage } from "@inertiajs/vue3";

const viewMode = inject<Ref<string | undefined>>("viewMode", ref(undefined));
const isNavOpened = ref(false);
const page = usePage();

function toggleNav() {
    isNavOpened.value = !isNavOpened.value;
}

watch(isNavOpened, (newVal) => {
    if (newVal == true && viewMode.value === "mobile") {
        document.documentElement.style.setProperty("--navwidth", "calc(2/3 * 100%)");
    } else if (viewMode.value !== "mobile") {
        newVal = false;
    }
});
</script>
<template>
    <nav class="flex flex-row absolute w-full h-full">
        <div
            data-open="isNavOpened"
            id="navbar"
            class="z-50 flex flex-col absolute overflow-clip h-dvh bg-background-lighter"
        >
            <div class="py-5 px-3 mb-3 w-full flex justify-center text-xl font-semibold">
                BankDash
            </div>
        </div>
        <Header @toggleNav="toggleNav">{{ $capitalize(page.props.routeName) }}</Header>
    </nav>
</template>
